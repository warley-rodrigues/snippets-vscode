{
  "name": "Baseons",
  "scopeName": "text.html.baseons",
  "fileTypes": ["bns.php"],
  "patterns": [
    { "include": "#baseons-comment" },
    { "include": "#baseons-echo" },
    { "include": "#baseons-php-block" },
    { "include": "#baseons-directive" },
    { "include": "text.html.basic" }
  ],
  "repository": {
    "baseons-comment": {
      "patterns": [
        {
          "name": "comment.block.baseons",
          "begin": "\\{\\{--",
          "end": "--\\}\\}"
        }
      ]
    },

    "baseons-echo": {
      "patterns": [
        {
          "name": "meta.embedded.block.php.baseons",
          "begin": "\\{\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.baseons" }
          },
          "end": "\\}\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.baseons" }
          },
          "patterns": [
            {
              "include": "source.php"
            }
          ]
        }
      ]
    },

    "baseons-php-block": {
      "patterns": [
        {
          "name": "meta.embedded.block.php.baseons",
          "begin": "@php",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.baseons"
            }
          },
          "end": "@endphp",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.baseons"
            }
          },
          "patterns": [
            {
              "include": "source.php"
            }
          ]
        }
      ]
    },

    "baseons-directive": {
      "patterns": [
        {
          "name": "keyword.control.baseons",
          "match": "@(?:if|else|elseif|foreach|while|for|endif|endfor|endforeach|section|endsection|endwhile|break|continue|include|yield|url|route|csrf|php|endphp)\\b"
        }
      ]
    }
  }
}
